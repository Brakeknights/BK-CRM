# ===========================================================================
# bk-phone configuration  —  copy this file to ".env" and fill in the blanks.
# NEVER commit the real .env (it holds secrets). It is gitignored.
# ===========================================================================

# Port the phone app runs on (separate from the CRM, which uses its own port).
PORT=3001

# Set to "production" on the live server (turns on the security guard + HTTPS-
# only cookies). Leave blank/unset for local development.
NODE_ENV=production

# ---- Shared database -------------------------------------------------------
# Absolute path to the SAME brakeknights.db the CRM uses, so customer names and
# profile links match. On Hostinger this lives outside the app folder so deploys
# don't wipe it. Example (adjust the path to your server):
DB_PATH=/home/youruser/brakeknights-data/brakeknights.db

# ---- App login -------------------------------------------------------------
# The password you'll type to open the app. Required in production (12+ chars).
PHONE_PASSWORD=
# A long random string used to sign the login cookie. Required in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHONE_SESSION_SECRET=

# ---- Telnyx (phone number provider) ---------------------------------------
TELNYX_API_KEY=
TELNYX_NUMBER=+17034230486
TELNYX_MESSAGING_PROFILE_ID=
# Used to verify inbound texts are genuinely from Telnyx. Paste your Telnyx
# Public Key here. (Until set, inbound webhooks are rejected for safety.)
TELNYX_PUBLIC_KEY=

# ---- CRM link --------------------------------------------------------------
# Base URL of your CRM, for the one-tap "View Profile" link in a conversation.
# Use https://dev.brakeknights.com on the dev app, https://brakeknights.com live.
CRM_BASE_URL=https://brakeknights.com
